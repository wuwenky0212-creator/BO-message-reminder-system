# 服务器配置
PORT=5000
NODE_ENV=development

# 数据库配置
# 可选值: sqlite, postgresql
DB_TYPE=sqlite

# SQLite 配置（当 DB_TYPE=sqlite 时使用）
SQLITE_PATH=./database.db

# PostgreSQL 配置（当 DB_TYPE=postgresql 时使用）
DB_HOST=localhost
DB_PORT=5432
DB_NAME=database_name
DB_USER=postgres
DB_PASSWORD=postgres123

# 其他配置
LOG_LEVEL=info
